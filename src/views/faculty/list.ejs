<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
</head>
<body class="<%= bodyClass %>">

    <main>
        <h1>Faculty Directory</h1>

        <p>
            Sort by: 
            <a href="/faculty?sort=name">Name</a> | 
            <a href="/faculty?sort=department">Department</a> |
            <a href="/faculty?sort=title">Title</a>

        </p>

        <ul>
            <% facultyList.forEach(member => { %>
                <li>
                    <a href="/faculty/<%= member.id %>">
                        <strong><%= member.name %></strong> - <%= member.role %> (<%= member.department %>)
                    </a>
                </li>
            <% }) %>
        </ul>
    </main>

</body>
</html>