<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
</head>
<body class="<%= bodyClass %>">

    <main>
        <p><a href="/faculty">← Back to Faculty Directory</a></p>

        <article>
            <h1><%= member.name %></h1>
            <h2><%= member.role %></h2>
            
            <hr>

            <section>
                <p><strong>Department:</strong> <%= member.department %></p>
                <p><strong>Email:</strong> <a href="mailto:<%= member.email %>"><%= member.email %></a></p>
                <p><strong>Office:</strong> <%= member.office %></p>
            </section>

            <section>
                <h3>Biography</h3>
                <p><%= member.bio %></p>
            </section>
        </article>
    </main>

</body>
</html>